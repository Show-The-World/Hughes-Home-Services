                </div>
            </div>
        </div>
        <div class="-card-info blockedSection5 bgContrast1 dropshadow1">
            <img eleventy:ignore src="/graphics/icon_email_accent.svg" alt="" class="icon -icon-circlePadding">
            <div class="container spread">
                <h3>Email</h3>
                <div class="subContainer">
                    <a href="mailto:wendallhughes58@gmail.com">wendallhughes58@gmail.com</a>
                </div>
            </div>
        </div>
        <div class="-card-info blockedSection5 bgContrast1 dropshadow1">
            <img eleventy:ignore src="/graphics/icon_location_accent.svg" alt="" class="icon -icon-circlePadding">
